# REQUIRED: LLM provider credentials (works with OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OPTIONAL: Use Bifrost as local proxy (run: just bifrost)
# OPENAI_BASE_URL=http://localhost:9090/litellm

# OPTIONAL: override defaults
# FEDOTMAS_DEFAULT_MODEL=openai/gpt-oss-120b
# FEDOTMAS_WORKER_MODELS=  # comma-separated
# FEDOTMAS_META_AGENT_MODEL=
# FEDOTMAS_META_AGENT_TEMPERATURE=0.3
# FEDOTMAS_DEFAULT_MAX_LOOP_ITERATIONS=3
# FEDOTMAS_LOG_LEVEL=DEBUG
# FEDOTMAS_LOG_DIR=~/.local/state/fedotmas/log
