# REQUIRED: LLM provider credentials (works with OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# OPTIONAL: Use Bifrost as local proxy (run: just bifrost)
#
# OPENAI_BASE_URL=http://localhost:9090/v1

# OPTIONAL: fedotmas core settings
#
# FEDOTMAS_DEFAULT_MODEL=openai/gpt-oss-120b
# FEDOTMAS_WORKER_MODELS=  # comma-separated
# FEDOTMAS_META_AGENT_MODEL=
# FEDOTMAS_META_AGENT_TEMPERATURE=0.3
# FEDOTMAS_DEFAULT_MAX_LOOP_ITERATIONS=3
# FEDOTMAS_LOG_LEVEL=DEBUG
# FEDOTMAS_LOG_DIR=~/.local/state/fedotmas/log

# OPTIONAL: MCP servers
#
# Transport (default: stdio). To run over HTTP, pass per-server:
#   FASTMCP_TRANSPORT=http FASTMCP_PORT=9001 uv run ... mcp-sandbox
# See mcp-servers/README.md for details.
#
# mcp-media: model overrides (default: google/gemini-2.5-flash)
# MEDIA_MODEL=google/gemini-2.5-flash
# MEDIA_AUDIO_MODEL=
# MEDIA_IMAGE_MODEL=
# MEDIA_VIDEO_MODEL=
#
# mcp-document: vision model for embedded image descriptions
# DOCUMENT_VISION_MODEL=google/gemini-2.5-flash
#
# mcp-web-scraping: Lightpanda headless browser (install: just lightpanda-install)
# No env vars required — browser runs locally without API keys
# LIGHTPANDA_DISABLE_TELEMETRY=true
#
# mcp-browser-usage: browser-use interactive automation (install: just browser-use-install)
BROWSER_USE_HEADLESS=true
# BROWSER_USE_LLM_MODEL=openai/gpt-4o-mini
# BROWSER_USE_ALLOWED_DOMAINS=
#
# mcp-sandbox: E2B cloud sandbox (requires API key from https://e2b.dev)
# E2B_API_KEY=
#
# mcp-websearch-searxng
# SEARXNG_URL=http://localhost:18888